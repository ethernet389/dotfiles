{
  "layer": "bottom",
  "position": "top",
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["sway/language", "clock", "tray"],
  "modules-right": ["cpu", "memory", "backlight", "wireplumber", "network", "battery"],

  "clock": {
    "format": "{:%Y-%m-%d %H-%M-%S}",
    "interval": 1
  },

  "cpu": {
    "format": "CPU: {usage}%",
  },

  "memory": {
    "format": "MEM: {percentage}% ({used} GiB)",
    "unit": "GiB"
  },

  "backlight": {
    "on-click": "~/.config/waybar/brightnessctl_toggle.sh",
    "format": "BRI: {percent}%"
  },

  "wireplumber": {
    "format": "VOL: {volume}%",
    "format-muted": "VOL (MUTE): {volume}%",
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "scroll-step": 2
  },

  "network": {
    "format-wifi": "WIFI ({essid}): {signalStrength}%",
    "format-ethernet": "ETH: {bandwidthTotalBytes} bytes/sec",
    "format-disconnected": "No Signal"
  },

  "battery": {
	"interval": 60,
	"states": {
		"warning": 30,
		"critical": 15,
		"predeath": 5
	},
	"events": {
		"on-discharging-warning": "notify-send -u normal 'Low Battery'",
		"on-discharging-critical": "notify-send -u critical 'Very Low Battery'",
		"on-discharging-predeath": "notify-send -u critical 'Pre-death Battery'",
		"on-charging-100": "notify-send -u normal 'Battery full'"
	},
    "format": "BAT: {capacity}% {time}"
  }
}
